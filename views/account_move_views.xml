<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_metre" model="ir.ui.view">
        <field name="name">account.move.form.inherit.metre</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            
            <!-- Add field to invoice lines tree inside the invoice_lines page -->
            <xpath expr="//page[@name='invoice_tab']//field[@name='invoice_line_ids']/tree/field[@name='quantity']" position="after">
                <field name="x_previous_reading" string="Previous Reading" optional="show"/>
                <field name="x_new_reading" string="New Reading" optional="show"/>
                <field name="x_actual_consumption" string="Actual Consumption" optional="show"/>
            </xpath>
            
        </field>
    </record>
</odoo>